{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["esnext", "dom", "es2024"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@app": ["src"],
      "@components": ["src/components"],
      "@services": ["src/services"],
      "@hooks": ["src/hooks"],
      "@store": ["src/store"],
      "@navigation": ["src/navigation"],
      "@utils": ["src/utils"],
      "@database": ["src/database"],
      "@screens": ["src/screens"],
      "@types": ["node_modules/@types"],
      "react-native": ["node_modules/react-native"],
      "react": ["node_modules/react"],
      "maplibre": ["node_modules/@maplibre/maplibre-react-native"],
      "geolocation": ["node_modules/react-native-geolocation-service"],
      "permissions": ["node_modules/react-native-permissions"],
      "sensors": ["node_modules/react-native-sensors"],
      "fs": ["node_modules/react-native-fs"],
      "sqlite": ["node_modules/react-native-sqlite-storage"]
    },
    "jsx": "react"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}